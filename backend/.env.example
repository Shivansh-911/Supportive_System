# Copy to .env.development, .env.beta, or .env.production and fill in real values.
# The active file is selected at startup by the DJANGO_ENV env var
# (defaults to 'development' when unset).

SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=
DATABASE_URL=postgres://user:pass@host:5432/dbname

# LLM / embedding providers
# OPENAI_API_KEY is required when EMBEDDING_PROVIDER / PROCESS_AGENT_PROVIDER /
# QUESTION_AGENT_PROVIDER in constants.py are set to "openai" (the current default).
# ANTHROPIC_API_KEY is only needed if you flip any of those providers to "anthropic".
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# New Relic APM
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=
